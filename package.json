{
  "name": "@vnyb/vue-route-query",
  "version": "1.1.0-vnyb.0",
  "packageManager": "pnpm@11.1.1",
  "description": "Type-safe URL query parameter synchronization for Vue 3 with Zod validation",
  "keywords": [
    "vue",
    "vue3",
    "vue-router",
    "query",
    "url",
    "zod",
    "typescript",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vnyb/vue-route-query.git"
  },
  "license": "MIT",
  "author": "vnyb",
  "bugs": {
    "url": "https://github.com/vnyb/vue-route-query/issues"
  },
  "homepage": "https://github.com/vnyb/vue-route-query#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "start": "esno src/index.ts",
    "test": "npm run test:zod3 && npm run test:zod4",
    "test:zod3": "npm i --no-save --no-package-lock --legacy-peer-deps zod@^3.25.0 && vitest run",
    "test:zod4": "npm i --no-save --no-package-lock --legacy-peer-deps zod@^4.0.0 && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "release": "npm run lint && npm run typecheck && npm run build && bumpp && npm publish"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^4.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bumpp": "^10.1.0",
    "typescript": "5.8.3",
    "unbuild": "^3.5.0",
    "vitest": "^0.34.0",
    "vue": "3.5.13",
    "vue-router": "4.5.0",
    "zod": "^4.0.0"
  }
}
